# Cluster permitido: devnet o mainnet-beta. No reutilices valores devnet en Mainnet.
SOLANA_NETWORK=devnet
# Endpoint RPC del mismo cluster. No incluyas credenciales en este archivo versionado.
SOLANA_RPC_URL=https://api.devnet.solana.com
# Ruta externa a un keypair JSON; usa .secrets/, keys/ o una ruta fuera del repositorio.
SOLANA_KEYPAIR_PATH=
# Mainnet: ruta externa a un mint keypair previamente creado y dirección pública de producción designada.
AVICOIN_MINT_KEYPAIR_PATH=
AVICOIN_PRODUCTION_WALLET=
# Cada ejecución Mainnet acepta exactamente una operación. Déjalo vacío normalmente.
AVICOIN_MAINNET_OPERATION=
ALLOW_MAINNET=false
# Wallet educativa separada para la prueba Orca; ambas variables deben quedar vacías hasta designarla.
AVICOIN_TEST_WALLET=
AVICOIN_TEST_KEYPAIR_PATH=
# Propuesta inicial de identidad y tokenomics.
TOKEN_NAME=AVICOIN
TOKEN_SYMBOL=AVI
TOKEN_DECIMALS=9
TOKEN_SUPPLY=100000000
# Se completarán únicamente cuando existan.
TOKEN_MINT_ADDRESS=
# URI HTTPS/IPFS/Arweave ya publicada; este proyecto no sube metadata.
TOKEN_METADATA_URI=
