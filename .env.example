# Cluster permitido: devnet o mainnet-beta. Mainnet requiere además ALLOW_MAINNET=true y confirmación interactiva.
SOLANA_NETWORK=devnet
# Endpoint RPC del mismo cluster. No incluyas credenciales en este archivo versionado.
SOLANA_RPC_URL=https://api.devnet.solana.com
# Ruta externa a un keypair JSON; usa .secrets/, keys/ o una ruta fuera del repositorio.
SOLANA_KEYPAIR_PATH=
ALLOW_MAINNET=false
# Propuesta inicial de identidad y tokenomics.
TOKEN_NAME=AVICOIN
TOKEN_SYMBOL=AVI
TOKEN_DECIMALS=9
TOKEN_SUPPLY=100000000
# Se completarán únicamente cuando existan.
TOKEN_MINT_ADDRESS=
# URI HTTPS/IPFS/Arweave ya publicada; este proyecto no sube metadata.
TOKEN_METADATA_URI=
